    "/api/v1/weather/wind-field": {
      "get": {
        "tags": [
          "weather"
        ],
        "summary": "Get Wind Field",
        "operationId": "get_wind_field_api_v1_weather_wind_field_get",
        "parameters": [
          {
            "name": "at_utc",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time",
              "title": "At Utc"
            }
          },
          {
            "name": "flight_level",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 410,
              "minimum": 300,
              "default": 350,
              "title": "Flight Level"
            }
          },
          {
            "name": "origin_latitude_deg",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "maximum": 90,
              "minimum": -90,
              "title": "Origin Latitude Deg"
            }
          },
          {
            "name": "origin_longitude_deg",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "maximum": 180,
              "minimum": -180,
              "title": "Origin Longitude Deg"
            }
          },
          {
            "name": "destination_latitude_deg",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "maximum": 90,
              "minimum": -90,
              "title": "Destination Latitude Deg"
            }
          },
          {
            "name": "destination_longitude_deg",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "maximum": 180,
              "minimum": -180,
              "title": "Destination Longitude Deg"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WindFieldResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
