{
  "$id": "https://aeroroute.dev/contracts/explanation-output/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "1.0.0"
    },
    "fallback_used": {
      "type": "boolean"
    },
    "provider": {
      "enum": [
        "template",
        "mlx"
      ]
    },
    "text": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "contract_version",
    "provider",
    "text",
    "fallback_used"
  ],
  "type": "object"
}
