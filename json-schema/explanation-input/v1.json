{
  "$id": "https://aeroroute.dev/contracts/explanation-input/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "allowed_numeric_values": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "contract_version": {
      "const": "1.0.0"
    },
    "summary": {
      "maxLength": 2000,
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "contract_version",
    "summary",
    "allowed_numeric_values"
  ],
  "type": "object"
}
