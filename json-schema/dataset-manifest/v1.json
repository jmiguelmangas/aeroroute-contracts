{
  "$id": "https://aeroroute.dev/contracts/dataset-manifest/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "1.0.0"
    },
    "sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "source_kind": {
      "enum": [
        "synthetic",
        "public"
      ]
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "version",
    "sha256",
    "contract_version",
    "source_kind"
  ],
  "type": "object"
}
